{
    "files.associations": {
        "*.h": "c",
        "bsp.h": "c",
        "motor_basic.h": "c",
        "ostream": "c",
        "format": "c",
        "cstdint": "c",
        "random": "c",
        "compare": "c",
        "variant": "c",
        "limits": "c",
        "string": "c",
        "vector": "c",
        "bit": "c",
